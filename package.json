{
  "name": "pumice",
  "version": "0.1.0",
  "description": "Lightweight, vault-free markdown viewer",
  "main": "main/index.js",
  "type": "module",
  "bin": {
    "pumice": "bin/pumice.js"
  },
  "scripts": {
    "start": "electron .",
    "build": "node scripts/build.js",
    "dev": "node scripts/build.js --watch &  electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "markdown",
    "viewer",
    "editor",
    "electron"
  ],
  "license": "MIT",
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "electron": "^40.8.0",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.37",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.12.3",
    "path-browserify": "^1.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "vitest": "^4.0.18"
  }
}
